read_clipboard = function(header = TRUE,
sep = "\t",
na.strings = c("", "NA"),
check.names = TRUE,
stringsAsFactors = FALSE,
dec = ".",
...) {
# 운영체제에 맞는 클립보드 읽기 방법 결정
if (Sys.info()['sysname'] == "Windows") {
# Windows에서는 기본적으로 clipboard()로 읽음
con <- readr::clipboard()
return(read.table(text = con, sep = sep, header = header, check.names = check.names,
na.strings = na.strings, stringsAsFactors = stringsAsFactors, dec = dec, ...))
} else {
# Linux/macOS에서는 xclip을 사용하여 클립보드를 읽음
read.xclip = function() {
if (!isTRUE(file.exists(Sys.which("xclip")[1L]))) {
stop("Cannot find xclip. Please install xclip to use this function on Linux/macOS.")
}
con <- pipe("xclip -o -selection c", "r")
on.exit(close(con))
read.table(file = con, sep = sep, header = header, check.names = check.names,
na.strings = na.strings, stringsAsFactors = stringsAsFactors, dec = dec, ...)
}
tryCatch({
read.xclip()
}, error = function(e) {
message(sprintf("Error: %s", e$message))
})
}
}
# 함수 실행 예시
read_clipboard()
# 함수 실행 예시
read_clipboard()
read_clipboard = function(header = TRUE,
sep = "\t",
na.strings = c("", "NA"),
check.names = TRUE,
stringsAsFactors = FALSE,
dec = ".",
...) {
# 운영체제에 맞는 클립보드 읽기 방법 결정
if (Sys.info()['sysname'] == "Windows") {
# Windows에서는 기본적으로 clipboard()로 읽음
con <- readr::clipboard()
return(read.table(text = con, sep = sep, header = header, check.names = check.names,
na.strings = na.strings, stringsAsFactors = stringsAsFactors, dec = dec, ...))
} else {
# Linux/macOS에서는 xsel을 사용하여 클립보드를 읽음
read.xsel = function() {
if (!isTRUE(file.exists(Sys.which("xsel")[1L]))) {
stop("Cannot find xsel. Please install xsel to use this function on Linux/macOS.")
}
con <- pipe("xsel --clipboard --output", "r")
on.exit(close(con))
read.table(file = con, sep = sep, header = header, check.names = check.names,
na.strings = na.strings, stringsAsFactors = stringsAsFactors, dec = dec, ...)
}
tryCatch({
read.xsel()
}, error = function(e) {
message(sprintf("Error: %s", e$message))
})
}
}
# 함수 실행 예시
read_clipboard()
read_clipboard = function(header = TRUE,
sep = "\t",
na.strings = c("", "NA"),
check.names = TRUE,
stringsAsFactors = FALSE,
dec = ".",
...) {
# 운영체제에 맞는 클립보드 읽기 방법 결정
if (Sys.info()['sysname'] == "Windows") {
# Windows에서는 기본적으로 clipboard()로 읽음
con <- readr::clipboard()
return(read.table(text = con, sep = sep, header = header, check.names = check.names,
na.strings = na.strings, stringsAsFactors = stringsAsFactors, dec = dec, ...))
} else {
# Linux/macOS에서는 wl-clipboard을 사용하여 클립보드를 읽음
read.wl_clipboard = function() {
if (!isTRUE(file.exists(Sys.which("wl-paste")[1L]))) {
stop("Cannot find wl-paste. Please install wl-clipboard to use this function on Wayland.")
}
con <- pipe("wl-paste -p", "r")
on.exit(close(con))
read.table(file = con, sep = sep, header = header, check.names = check.names,
na.strings = na.strings, stringsAsFactors = stringsAsFactors, dec = dec, ...)
}
tryCatch({
read.wl_clipboard()
}, error = function(e) {
message(sprintf("Error: %s", e$message))
})
}
}
# 함수 실행 예시
read_clipboard()
