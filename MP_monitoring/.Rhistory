library(shiny)
library(shinyjs)
# UI 정의
ui <- fluidPage(
useShinyjs(),  # shinyjs를 사용하여 JavaScript 기능 사용
titlePanel("Clipboard Example"),
# 클립보드 버튼
actionButton("get_clipboard", "Get Clipboard Content"),
# 클립보드 내용을 보여줄 텍스트 출력
textOutput("clip_text")
)
# 서버 정의
server <- function(input, output, session) {
# 클립보드 내용을 저장할 변수
clipboard_text <- reactiveVal(NULL)
# 클립보드 내용을 읽어오는 JavaScript 코드 실행
observeEvent(input$get_clipboard, {
# 클립보드 텍스트 읽기
runjs('
navigator.clipboard.readText().then(function(text) {
Shiny.setInputValue("clipboard_text", text);
}).catch(function(err) {
console.log("Failed to read clipboard: " + err);
Shiny.setInputValue("clipboard_text", "Failed to read clipboard");
});
')
})
# 클립보드 텍스트 출력
output$clip_text <- renderText({
req(input$clipboard_text)
input$clipboard_text
})
}
# Shiny 앱 실행
shinyApp(ui = ui, server = server)
