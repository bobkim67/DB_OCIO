library(shiny)
ui <- fluidPage(
tags$h2("Clipboard Reader in Shiny"),
actionButton("read_clipboard", "Read Clipboard"),
verbatimTextOutput("clipboard_content"),
tags$script(HTML("
document.getElementById('read_clipboard').addEventListener('click', async function() {
try {
// 권한 상태 확인 및 요청
navigator.permissions.query({name: 'clipboard-read'})
.then(function(result) {
if (result.state == 'granted' || result.state == 'prompt') {
// 클립보드 내용 읽기
navigator.clipboard.readText()
.then(text => {
// Shiny로 데이터 전송
Shiny.setInputValue('clipboard_text', text);
})
.catch(err => {
console.error('클립보드 읽기 오류: ', err);
Shiny.setInputValue('clipboard_text', 'ERR: 클립보드 읽기 오류: ' + err.message);
});
} else {
// 권한 거부 시 메시지 전달
Shiny.setInputValue('clipboard_text', 'ERR: 클립보드 접근 권한이 거부되었습니다.');
}
});
} catch (err) {
console.error('권한 확인 오류: ', err);
Shiny.setInputValue('clipboard_text', 'ERR: 권한 확인 오류: ' + err.message);
}
});
"))
)
server <- function(input, output, session) {
output$clipboard_content <- renderText({
req(input$clipboard_text)
if (startsWith(input$clipboard_text, "ERR:")) {
paste("Error:", input$clipboard_text)
} else {
paste("Clipboard content:", input$clipboard_text)
}
})
}
shinyApp(ui, server)
library(ecos)
ecos.setKey("FWC2IZWA5YD459SQ7RJM")
call_rate <- ecos::statSearch(stat_code = "817Y002","010101000",cycle ="D",
start_time = "20220101",
end_time =today() %>% str_remove_all("-") ) %>% tibble() %>%
mutate(기준일자= ymd(time),
`콜금리/365` = data_value/100/365) %>%
select(기준일자,`콜금리/365`)
