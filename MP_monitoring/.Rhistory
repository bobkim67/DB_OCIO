library(shiny)
ui <- fluidPage(
tags$h2("Secure Clipboard Reader"),
actionButton("clip_btn", "클립보드 읽기", class = "btn-primary"),
verbatimTextOutput("clip_output"),
tags$script(HTML('
document.getElementById("clip_btn").addEventListener("click", async () => {
try {
// 권한 상태 확인 (추가된 부분)
const permission = await navigator.permissions.query({ name: "clipboard-read" });
if (permission.state === "granted" || permission.state === "prompt") {
const text = await navigator.clipboard.readText();
Shiny.setInputValue("clip_data", text, { priority: "event" });
} else {
Shiny.setInputValue("clip_data", "ERR: 권한이 거부되었습니다");
}
} catch (error) {
Shiny.setInputValue("clip_data", "ERR: " + error.message);
}
});
'))
)
server <- function(input, output, session) {
output$clip_output <- renderText({
req(input$clip_data)
if(grepl("^ERR:", input$clip_data)) {
return(paste("오류 발생:", input$clip_data))
}
paste("클립보드 내용:\n", input$clip_data)
})
}
shinyApp(ui, server)
library(shiny)
ui <- fluidPage(
tags$h2("Clipboard Reader in Shiny"),
actionButton("read_clipboard", "Read Clipboard"),
verbatimTextOutput("clipboard_content"),
tags$script(HTML("
document.getElementById('read_clipboard').addEventListener('click', async function() {
try {
// 권한 상태 확인
const permission = await navigator.permissions.query({name: 'clipboard-read'});
if (permission.state === 'granted' || permission.state === 'prompt') {
// 클립보드 내용 읽기
const text = await navigator.clipboard.readText();
// Shiny로 데이터 전송
Shiny.setInputValue('clipboard_text', text);
} else {
// 권한 거부 시 메시지 전달
Shiny.setInputValue('clipboard_text', 'ERR: 클립보드 접근 권한이 거부되었습니다.');
}
} catch (err) {
console.error('Failed to read clipboard: ', err);
Shiny.setInputValue('clipboard_text', 'ERR: 클립보드 읽기 실패: ' + err.message);
}
});
"))
)
server <- function(input, output, session) {
output$clipboard_content <- renderText({
req(input$clipboard_text)
# 오류 메시지 처리
if (startsWith(input$clipboard_text, "ERR:")) {
paste("Error:", input$clipboard_text)
} else {
paste("Clipboard content:", input$clipboard_text)
}
})
}
shinyApp(ui, server)
